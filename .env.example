# SUPABASE_URL / SUPABASE_ANON_KEY: server-only credentials (no VITE_ prefix) so
# they are never bundled into the browser JS. The frontend talks to Supabase only
# through /api/* routes in server.ts. Create a NEW Supabase project for this app
# (do not reuse Stegion-LOW's) and run supabase/schema.sql in its SQL Editor.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
